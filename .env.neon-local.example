# Create a personal Neon API key at https://console.neon.tech/app/settings/api-keys
NEON_API_KEY=

# Find this under Neon Console > Project Settings > General.
NEON_PROJECT_ID=

# Optional: branch from a specific production branch. When empty, Neon Local
# uses the project's default branch as the parent.
PARENT_BRANCH_ID=

# The local port exposed by Neon Local.
NEON_LOCAL_PORT=5432
